# ========================================
# ModalIn Backend - Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ========================================

# Server
PORT=5000

# Database MongoDB
MONGODB_URI=mongodb://localhost:27017/modalin
# Jika pakai MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/modalin

# JWT Secret (buat string acak yang panjang dan susah ditebak)
JWT_SECRET=modalin_secret_key_ganti_ini_dengan_string_random_panjang
JWT_EXPIRES_IN=7d

# Email (untuk kirim OTP lupa password)
# Gunakan Gmail App Password (bukan password biasa)
EMAIL_USER=emailkamu@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5173

# Upload
MAX_FILE_SIZE=10485760
# 10MB = 10 * 1024 * 1024
